<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="20" alignment="TOP_LEFT" prefWidth="500" styleClass="card"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.GUI.ForumAddPostController"
      stylesheets="@styles.css">

    <!-- Titre de la page -->
    <VBox spacing="5">
        <Label text="📝 Nouveau Post" styleClass="title-label"/>
        <Label text="Partagez vos idées avec la communauté TalentFlow" styleClass="subtitle-label"/>
    </VBox>

    <Separator opacity="0.4"/>

    <!-- Formulaire -->
    <VBox spacing="15">
        <VBox spacing="5">
            <Label text="Titre" style="-fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
            <TextField fx:id="titleField" promptText="Donnez un titre accrocheur à votre post"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Contenu" style="-fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
            <TextArea fx:id="contentField" promptText="Qu'avez-vous en tête ?" prefHeight="180" wrapText="true"/>
        </VBox>
    </VBox>

    <!-- Image (optionnel) -->
    <VBox spacing="5">
        <Label text="Image (Optionnel)" style="-fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="📷 Choisir une image" onAction="#handleUploadImage" styleClass="btn-secondary"/>
            <Label fx:id="imageNameLabel" text="Aucun fichier sélectionné" styleClass="subtitle-label"/>
        </HBox>
        <ImageView fx:id="imagePreview" fitWidth="200" fitHeight="150" preserveRatio="true" visible="false" managed="false"/>
    </VBox>

    <!-- Actions -->
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Publier sur TalentFlow" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.GUI.CandidatCandidatureController"
      spacing="12" style="-fx-padding: 20;">

    <!-- Titre -->
    <Label text="👤 Espace Candidat — Postuler aux offres"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #6c5ce7;">
        <VBox.margin><Insets bottom="5"/></VBox.margin>
    </Label>

    <HBox spacing="14">
        <!-- Formulaire de candidature -->
        <VBox spacing="12" prefWidth="480"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
            <Label text="Nouvelle Candidature" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="70"/>
                </columnConstraints>
                <Label text="ID Offre :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfOffreId" editable="false" promptText="Sélectionnez une offre →"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Lien CV :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfCvUrl" promptText="https://drive.google.com/..."
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Email :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfEmail" promptText="votre@email.com"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Motivation :" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="taMotivation" prefRowCount="3" promptText="Décrivez vos motivations..."
                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="📤 Postuler" onAction="#handlePostuler"
                        style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20;"/>
                <Button text="✏ Modifier" onAction="#handleModifier"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 16;"/>
                <Button text="🗑 Supprimer" onAction="#handleSupprimer"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 16;"/>
                <Button text="🧹 Vider" onAction="#handleVider"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 16;"/>
            </HBox>
            <Label fx:id="lblMsg" wrapText="true" style="-fx-font-size: 12px;"/>
        </VBox>

        <!-- Liste des offres disponibles -->
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
            <Label text="💼 Offres disponibles (cliquez pour sélectionner)"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
            <TableView fx:id="tvOffres" prefHeight="280" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colOffreListId" text="ID" prefWidth="45"/>
                    <TableColumn fx:id="colOffreListTitre" text="Poste" prefWidth="200"/>
                    <TableColumn fx:id="colOffreListLoc" text="Localisation" prefWidth="120"/>
                    <TableColumn fx:id="colOffreListStatut" text="Statut" prefWidth="90"/>
                    <TableColumn fx:id="colOffreListPostule" text="Postulé ?" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>

    <!-- Historique des candidatures du candidat -->
    <VBox spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="📋 Mon historique de candidatures (cliquez pour modifier)"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📎 Gérer pièces jointes" onAction="#handleGererPieces"
                    style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 16;"/>
        </HBox>
        <TableView fx:id="tvMesCandidatures" prefHeight="250" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="45"/>
                <TableColumn fx:id="colOffreId" text="Offre" prefWidth="55"/>
                <TableColumn fx:id="colTitreOffre" text="Poste" prefWidth="160"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="95"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="130"/>
                <TableColumn fx:id="colCv" text="URL CV" prefWidth="130"/>
                <TableColumn fx:id="colMotivation" text="Motivation" prefWidth="280"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
